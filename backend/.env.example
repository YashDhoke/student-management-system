PORT=5001
DATABASE_URL=postgresql://user:password@localhost:5432/student_db

# Server environment: development | production | test
NODE_ENV=development

# Log level: error | warn | info | http | verbose | debug
LOG_LEVEL=info

# Production only: comma-separated list of allowed frontend origins
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app
# Leave unset in development to allow all origins (*)
ALLOWED_ORIGINS=